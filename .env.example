# Generate a strong secret with:  openssl rand -hex 32
NEXTAUTH_SECRET=aura-dev-secret-change-me-in-prod-32chars-min
NEXTAUTH_URL=http://localhost:3000

# Prisma (auth DB) - SQLite by default; switch to Postgres for production
DATABASE_URL=file:./db/custom.db

# OAuth providers:
#   Spotify - https://developer.spotify.com/dashboard
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

#Spotify:
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Feature flags shown to the UI (don't enable a provider whose creds aren't set)
NEXT_PUBLIC_GITHUB_ENABLED=false
NEXT_PUBLIC_SPOTIFY_ENABLED=false
