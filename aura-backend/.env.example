# AURA Backend environment — local dev with embedded Postgres (pgserver).
# Postgres runs on a unix socket only; we connect via the socket path.

APP_NAME=AURA
VERSION=0.3.0
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=dev

# Postgres (socket-based — pgserver runs without TCP)
POSTGRES_DSN=postgresql://aura:aura@/aura?host=/home/z/my-project/aura-backend/pgdata
PGHOST=/home/z/my-project/aura-backend/pgdata
PGUSER=aura
PGPASSWORD=aura
PGDATABASE=aura

# Redis (in-process fallback used by real_redis when server is unreachable)
REDIS_URL=redis://localhost:6379/0

# Qdrant : local file-mode fallback at qdrant_data/
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aura_embeddings
QDRANT_LOCAL_PATH=/home/z/my-project/aura-backend/qdrant_data

# MLflow (optional — skipped if unreachable)
MLFLOW_TRACKING_URI=http://localhost:5000

# ClickHouse + Kafka (skipped if unreachable — no mock fallback)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=aura
CLICKHOUSE_PASSWORD=aura
CLICKHOUSE_DATABASE=aura
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_USER_ACTIONS=aura.user_actions
KAFKA_TOPIC_WS_EVENTS=aura.ws_events
KAFKA_CONSUMER_GROUP=aura-backend

# LLM : Groq
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Embeddings (local sentence-transformers model — runs in-process)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# RL
RL_ALGORITHM=ppo
RL_STATE_DIM=32
RL_ACTION_DIM=32
RL_GAMMA=0.99
RL_LR=3e-4
RL_CLIP_EPS=0.2
RL_BATCH_SIZE=64
RL_BUFFER_SIZE=10000
RL_TRAIN_INTERVAL_STEPS=10
RL_MLFLOW_EXPERIMENT=aura-rl-ppo

# Recommendation rankers
RECSYS_NEURAL_CF_DIM=64
RECSYS_NEURAL_CF_LAYERS=[128, 64]
RECSYS_CF_FACTORS=32
RECSYS_CF_EPOCHS=15
RECSYS_CATALOG_REFRESH_SEC=300

# Auth (must match NextAuth frontend secret)
NEXTAUTH_SECRET=aura-dev-secret-change-me-in-prod-32chars-min
NEXTAUTH_URL=http://localhost:3000
JWT_ALG=HS256
JWT_ISSUER=aura-nextauth

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:81","http://127.0.0.1:81"]

# Feature flags — graceful skip when service is unreachable
USE_REAL_POSTGRES=true
USE_REAL_REDIS=true
USE_REAL_QDRANT=true
USE_REAL_CLICKHOUSE=true
USE_REAL_KAFKA=true
USE_REAL_LLM=true
USE_REAL_RL=true
USE_REAL_MCP=true
USE_REAL_RECSYS=true
USE_REAL_EMBEDDINGS=true
